<Project>
  <PropertyGroup>
    <!-- Manually bump Major.Minor.Patch in this file before each release -->
    <Version>3.6.0</Version>

    <!-- AssemblyVersion stays locked to Major to maintain binary compatibility -->
    <AssemblyVersion>3.0.0.0</AssemblyVersion>

    <!-- FileVersion is overridden in CI with the build number (e.g. 3.1.0.42) -->
    <!-- Locally it defaults to Version (3.1.0.0) -->
    <FileVersion>$(Version).0</FileVersion>

    <!-- Assembly metadata — applies to all projects in this repo -->
    <Company>Netwrix Corporation</Company>
    <Product>PingCastle</Product>
    <Copyright></Copyright>
    <IncludeSourceRevisionInInformationalVersion>false</IncludeSourceRevisionInInformationalVersion>
    <!-- StyleCop: deferred — suppress all SA/SX rules repo-wide -->
    <NoWarn>$(NoWarn);SA1633;SA1200;SA1201;SA1202;SA1203;SA1204;SA1208;SA1210;SA1300;SA1303;SA1306;SA1307;SA1309;SA1310;SA1311;SA1400;SA1401;SA1402;SA1403;SA1404;SA1405;SA1406;SA1407;SA1408;SA1409;SA1410;SA1411;SA1500;SA1501;SA1502;SA1503;SA1504;SA1505;SA1506;SA1507;SA1508;SA1509;SA1510;SA1511;SA1512;SA1513;SA1514;SA1515;SA1516;SA1517;SA1518;SA1519;SA1520;SA1600;SA1601;SA1602;SA1603;SA1604;SA1605;SA1606;SA1607;SA1608;SA1609;SA1610;SA1611;SA1612;SA1613;SA1614;SA1615;SA1616;SA1617;SA1618;SA1619;SA1620;SA1621;SA1622;SA1623;SA1624;SA1625;SA1626;SA1627;SA1628;SA1629;SA1630;SA1631;SA1632;SA1634;SA1635;SA1636;SA1637;SA1638;SA1639;SA1640;SA1641;SA1642;SA1643;SA1644;SA1645;SA1646;SA1647;SA1648;SA1649;SA1650;SA1651;SA0001;SA0002;SA1000;SA1001;SA1002;SA1003;SA1004;SA1005;SA1006;SA1007;SA1008;SA1009;SA1010;SA1011;SA1012;SA1013;SA1014;SA1015;SA1016;SA1017;SA1018;SA1019;SA1020;SA1021;SA1022;SA1023;SA1024;SA1025;SA1026;SA1027;SA1028;SA1100;SA1101;SA1102;SA1103;SA1104;SA1105;SA1106;SA1107;SA1108;SA1109;SA1110;SA1111;SA1112;SA1113;SA1114;SA1115;SA1116;SA1117;SA1118;SA1119;SA1120;SA1121;SA1122;SA1123;SA1124;SA1125;SA1126;SA1127;SA1128;SA1129;SA1130;SA1131;SA1132;SA1133;SA1134;SA1135;SA1136;SA1137;SA1138;SA1139;SA1140;SA1141;SA1142;SX1101;SX1309;SX1309S</NoWarn>
  </PropertyGroup>

  <!-- Release builds: no .pdb files in output -->
  <PropertyGroup Condition="'$(Configuration)' == 'Release'">
    <DebugType>None</DebugType>
    <DebugSymbols>false</DebugSymbols>
  </PropertyGroup>
</Project>
