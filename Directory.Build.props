<Project>
  <PropertyGroup>
    <!-- Manually bump Major.Minor.Patch in this file before each release -->
    <Version>3.1.0</Version>

    <!-- AssemblyVersion stays locked to Major to maintain binary compatibility -->
    <AssemblyVersion>3.0.0.0</AssemblyVersion>

    <!-- FileVersion is overridden in CI with the build number (e.g. 3.1.0.42) -->
    <!-- Locally it defaults to Version (3.1.0.0) -->
    <FileVersion>$(Version).0</FileVersion>

    <!-- Assembly metadata — applies to all projects in this repo -->
    <Company>Netwrix Corporation</Company>
    <Product>PingCastle</Product>
    <Copyright></Copyright>
    <IncludeSourceRevisionInInformationalVersion>false</IncludeSourceRevisionInInformationalVersion>
  </PropertyGroup>
</Project>
